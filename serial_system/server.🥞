fun main() {
    // memset @base[7] to @base[64] to 0 for global variables
	var start = @base + WORD_SIZE*7;
	var end = FUNC_BASE;
	while (start < end) {
		stw start, 0;
		start = start + WORD_SIZE;
	}

    // init the shared ring buffers
	var rx_ring = 0;
	var tx_ring = 0;
	rx_ring = get_rx_ring();
	tx_ring = get_tx_ring();

	var rx_avail = 0;
	var tx_avail = 0;
	rx_avail = get_rx_avail();
	tx_avail = get_tx_avail();

	var rx_used = 0;
	var tx_used = 0;
	rx_used = get_rx_used();
	tx_used = get_tx_used();

	// Init the shared ring buffers
	ring_init(rx_ring, rx_avail, rx_used);
	ring_init(tx_ring, tx_avail, tx_used);

    var shared_dma = 0;
    shared_dma = get_shared_dma();

	// We will also need to populate these rings with memory from the shared dma region
	// Add buffers to the rx ring
	var i = 0;
    while (i < 511) {
        var ret = 0;
        ret = enqueue_avail(rx_ring, (shared_dma + (i * BUFFER_SIZE)), BUFFER_SIZE, 0);
		if (ret != 0) {
			// microkit_dbg_puts(microkit_name);
			// microkit_dbg_puts(": rx buffer population, unable to enqueue buffer\n");
			break;
		}
        i = i + 1;
    }

	// Add buffers to the tx ring
    // TODO: not sure why len is different
	i = 0;
	while (i < 511) {
	    var ret2 = 0;
	    ret2 = enqueue_avail(tx_ring, (shared_dma + (i * NUM_BUFFERS)), BUFFER_SIZE, 0);
		if (ret2 != 0) {
			// microkit_dbg_puts(microkit_name);
			// microkit_dbg_puts(": tx buffer population, unable to enqueue buffer\n");
			break;
		}
	    i = i + 1;
	}

	print_hello();
    return 0;
}

fun print_hello() {
	var test_string = @base + 1024;
	st8 test_string, 72; // H
	st8 test_string + 1, 69; // E
	st8 test_string + 2, 76; // L
	st8 test_string + 3, 76; // L
	st8 test_string + 4, 79; // O
	st8 test_string + 5, 33; // !
	st8 test_string + 6, 33; // !
	st8 test_string + 7, 33; // !
	st8 test_string + 8, 10; // \n
	print_string(test_string, 9);

	return 0;
}

fun get_rx_avail() {
	var rx_avail_addr = @base + WORD_SIZE;
	return (lds {1} rx_avail_addr);
}

fun get_rx_used() {
	var rx_used_addr = @base + WORD_SIZE*2;
	return (lds {1} rx_used_addr);
}

fun get_tx_avail() {
	var tx_avail_addr = @base + WORD_SIZE*3;
	return (lds {1} tx_avail_addr);
}

fun get_tx_used() {
	var tx_used_addr = @base + WORD_SIZE*4;
	return (lds {1} tx_used_addr);
}

fun get_shared_dma() {
	var vaddr_addr = @base + WORD_SIZE*5;
	return (lds {1} vaddr_addr);
}

fun get_rx_ring() {
	var ring_base = @base + WORD_SIZE*7;
	return ring_base;
}

fun get_tx_ring() {
	var ring_base = @base + WORD_SIZE*10;
	return ring_base;
}

export fun handle_getchar() {
	var char = 0;
	char = getchar();

	var temp_buff = FUNC_BASE + WORD_SIZE * 8;
	st8 temp_buff, char;
	print_string(temp_buff, 1);
	// if char == CTRL^C or char == CTRL^D or char == '\n'
	if (((char == 3) | (char == 4) | (char == 13)) != 0) {
		// print newline
		st8 temp_buff, 10;
		print_string(temp_buff, 1);
	}
	return 0;
}

fun getchar() {
	// Notify the driver that we want to get a character.
	// In Patrick's design, this increments the chars_for_clients value.
	@microkit_notify_getchar(0,0,0,0);

	var rx_ring = 0;
	rx_ring = get_rx_ring();
	var buffer_ptr = FUNC_BASE;
	var buffer_len_ptr = FUNC_BASE + WORD_SIZE;
	var cookie_ptr = FUNC_BASE + WORD_SIZE*2;

	var ret = 1;
	while (ret != 0) {
		ret = dequeue_used(rx_ring, buffer_ptr, buffer_len_ptr, cookie_ptr);
	}

	var buffer = lds {1} buffer_ptr;
	var buffer_len = lds {1} buffer_len_ptr;

	// We are only getting one character at a time
	var char = 0;
	!ld8 char, buffer;

	// Now that we are finished with the used buffer, we can add it back to the available ring
	ret = enqueue_avail(rx_ring, buffer, buffer_len, 0);
	if (ret != 0) {
		return -1;
	}

	return char;
}

fun print_string(1 string_ptr, 1 string_len) {
	var tx_ring = 0;
	tx_ring = get_tx_ring();

	var buffer_ptr = FUNC_BASE;
	var buffer_len_ptr = FUNC_BASE + WORD_SIZE;
	var cookie_ptr = FUNC_BASE + WORD_SIZE*2;

	// Dequeue a buffer from the available ring from the tx buffer
	var ret = 0;
	ret = dequeue_avail(tx_ring, buffer_ptr, buffer_len_ptr, cookie_ptr);
	if (ret != 0) {
		return -1;
	}

	var buffer = lds {1} buffer_ptr;

	// copy over the string to the buffer
	pnk_memcpy(buffer, string_ptr, string_len + 1);

	var tx_used_ring = lds {1} tx_ring;
	var is_empty = 0;
	is_empty = ring_empty(tx_used_ring);

	ret = enqueue_used(tx_ring, buffer, (string_len + 1), cookie_ptr);
	if (ret != 0) {
		return -1;
	}

	if (is_empty) {
		@microkit_notify_print(0,0,0,0);
	}
	return 0;
}
