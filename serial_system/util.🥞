#define STATIC_AREA_SIZE 512
#define FUNC_BASE @base + STATIC_AREA_SIZE

#define BIT(nr) (1 << nr)

#define UART_BYTE_MASK 255 // 0xFF
#define UART_URXD_READY_MASK BIT(15) // BIT(15)
#define SR2_OFFSET 152
#define UART_SR2_TXFIFO_EMPTY BIT(14) // BIT(14)
#define NUM_BUFFERS 512
#define BUFFER_SIZE 1024

#define WORD_SIZE 8

/* Copy `len` bytes from src to dst */
fun pnk_memcpy(1 dst, 1 src, 1 len) {
	var i = 0;
    var c = 0;
    while (i < len) {
        !ld8 c, (src + i);
        !st8 c, (dst + i);
        i = i + 1;
    }
	return 0;
}

/* Returns a % b, asuming b = x^n for some x and n */
fun pnk_modulo(1 a, 1 b) {
    var mask = b - 1;
    return a & mask;
}
